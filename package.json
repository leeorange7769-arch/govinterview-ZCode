{
  "name": "civil-service-interview",
  "version": "0.1.0",
  "private": true,
  "description": "公务员面试训练平台 - 全栈 monorepo",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:backend": "npm run dev --workspace backend",
    "dev:frontend": "npm run dev --workspace frontend",
    "glitch-start": "cd backend && npx prisma generate && npx prisma migrate deploy && npx tsx prisma/seed.ts && npx tsx src/server.ts",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "engines": {
    "node": ">=18"
  },
  "author": "",
  "license": "MIT"
}
