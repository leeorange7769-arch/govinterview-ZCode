{
  "envId": "{{envId}}",
  "version": "2.0",
  "framework": {
    "name": "civil-interview",
    "plugins": {
      "client": {
        "use": "@cloudbase/framework-plugin-website",
        "inputs": {
          "outputPath": "frontend/dist",
          "cloudPath": "/",
          "envVariables": {}
        }
      },
      "server": {
        "use": "@cloudbase/framework-plugin-function",
        "inputs": {
          "functionRootPath": "cloudfunctions",
          "functions": [
            {
              "name": "api",
              "timeout": 30,
              "runtime": "Nodejs18.15",
              "memorySize": 512,
              "envVariables": {
                "NODE_ENV": "production",
                "JWT_SECRET": "your-secret-change-me",
                "JWT_EXPIRES_IN": "7d",
                "CLIENT_URL": "*"
              },
              "installDependency": true
            }
          ]
        }
      }
    }
  }
}
