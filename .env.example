# ====== 后端环境变量示例 ======
# 复制本文件为 backend/.env 并填写真实值

# 运行环境
NODE_ENV=development
PORT=4000

# 数据库（开发期使用 SQLite，部署时切换为 PostgreSQL）
# SQLite（开发）：
DATABASE_URL="file:./dev.db"
# PostgreSQL（部署）：
# DATABASE_URL="postgresql://user:password@localhost:5432/civil_interview?schema=public"

# Redis（可选，开发期可不配）
REDIS_URL=""

# JWT 密钥（生产环境请使用强随机字符串）
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# OpenAI（AI 评分 / 分析）
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o-mini"

# 跨域（前端地址）
CLIENT_URL="http://localhost:5173"
